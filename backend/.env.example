APP_ENV=local
DATABASE_URL=sqlite:///./geo.db
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_URL=
SUPABASE_SERVICE_ROLE_KEY=
DEEPSEEK_API_KEY=
DOUBAO_API_KEY=
TONGYI_API_KEY=
